<Window x:Class="PresupuestoPro.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Entrada" Height="162" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding Prompt}" Margin="0,0,0,10"/>

        <TextBox Grid.Row="1" Text="{Binding ResponseText}" 
                 Margin="0,0,0,20" Padding="5"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancelar" Click="CancelButton_Click" 
                    Margin="0,0,10,0" Padding="10,5"/>
            <Button Content="Aceptar" Click="OkButton_Click" 
                    IsDefault="True" Padding="10,5"/>
        </StackPanel>
    </Grid>
</Window>