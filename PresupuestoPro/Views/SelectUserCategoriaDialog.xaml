<Window x:Class="PresupuestoPro.Views.UserCatalog.SelectUserCategoriaDialog"
            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            Title="Seleccionar Categoría de Destino"
            Width="340" Height="320"
            WindowStartupLocation="CenterOwner"
            ResizeMode="NoResize"
            Background="#F5F6FA">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                       Text="📁 ¿En qué categoría desea guardar el módulo?"
                       FontSize="13" FontWeight="SemiBold"
                       Foreground="#1565C0" Margin="0,0,0,10"
                       TextWrapping="Wrap"/>

        <ListBox Grid.Row="1"
                     x:Name="ListaCategorias"
                     Margin="0,0,0,10"
                     DisplayMemberPath="Nombre"
                     SelectionChanged="ListaCategorias_SelectionChanged"/>

        <Button Grid.Row="2"
                    Content="＋ Nueva Categoría"
                    Click="BtnNuevaCategoria_Click"
                    Background="White" BorderBrush="#BDBDBD"
                    BorderThickness="1" FontSize="11"
                    Padding="8,5" Margin="0,0,0,10"
                    HorizontalAlignment="Left"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="✓ Guardar aquí"
                        x:Name="BtnGuardar"
                        IsEnabled="False"
                        Click="BtnGuardar_Click"
                        Background="#1565C0" Foreground="White"
                        FontWeight="SemiBold" Padding="16,7" Margin="0,0,8,0"/>
            <Button Content="Cancelar"
                        Click="BtnCancelar_Click"
                        Background="White" BorderBrush="#BDBDBD"
                        BorderThickness="1" Padding="16,7"/>
        </StackPanel>
    </Grid>
</Window>