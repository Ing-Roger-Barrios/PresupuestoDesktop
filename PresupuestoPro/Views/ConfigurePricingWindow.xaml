<Window x:Class="PresupuestoPro.Views.ConfigurePricingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PresupuestoPro.ViewModels.Pricing"
        Title="Configurar Norma de Precios" Height="750" Width="800"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Selección de norma -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Norma existente:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <ComboBox ItemsSource="{Binding NormNames}" 
                      SelectedItem="{Binding SelectedNorm}"
                      Width="220" Height="28"/>
            <Button Content="Usar en proyecto"
                    Command="{Binding ApplySelectedNormCommand}"
                    Margin="12,0,0,0"
                    Padding="12,6"
                    Background="#1565C0"
                    Foreground="White"/>
        </StackPanel>

        <!-- Nombre de la norma actual -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="Nombre de esta norma:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox Text="{Binding CurrentName}" Width="200" Height="28"/>
            <Button Content="Nueva norma"
                    Command="{Binding CreateNewNormCommand}"
                    Margin="12,0,0,0"
                    Padding="12,6"/>
        </StackPanel>

        <Border Grid.Row="2"
                Margin="0,0,0,14"
                Padding="10,8"
                Background="#E3F2FD"
                BorderBrush="#90CAF9"
                BorderThickness="1"
                CornerRadius="6">
            <TextBlock>
                <Run Text="Norma del proyecto actual: "/>
                <Run Text="{Binding ProjectNormName}" FontWeight="Bold"/>
            </TextBlock>
        </Border>

        <!-- DataGrid -->
        <DataGrid Grid.Row="3" ItemsSource="{Binding Rules}"
                  AutoGenerateColumns="False" CanUserAddRows="False" RowHeight="30">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Parámetro" Binding="{Binding Code}" Width="80" IsReadOnly="True"/>
                <DataGridTextColumn Header="Descripción" Binding="{Binding Description}" Width="*" IsReadOnly="True"/>
                <DataGridTemplateColumn Header="%" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Percentage, Converter={StaticResource ZeroToEmptyConverter}}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding Percentage, StringFormat=N2}"
                     IsEnabled="{Binding IsEditable}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Fórmula" Binding="{Binding Formula}" Width="120" IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Botones -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <CheckBox Content="Establecer como predeterminada" IsChecked="{Binding IsDefault}" Margin="0,0,20,0"/>
            <Button Content="Guardar Norma" Command="{Binding SaveNormCommand}" 
                    Background="#1976D2" Foreground="White"
                    Padding="15,8" FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</Window>
