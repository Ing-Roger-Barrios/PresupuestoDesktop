<Window x:Class="PresupuestoPro.Views.NuevoRecursoLocalDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nuevo Recurso Local"
        Width="380" Height="394"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F6FA">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="👤 Nuevo Recurso Local"
                   FontSize="15" FontWeight="Bold"
                   Foreground="#E65100"
                   Margin="0,0,0,16"/>

        <!-- Nombre -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Nombre *" FontSize="11" Foreground="#757575" Margin="0,0,0,3"/>
            <TextBox x:Name="TxtNombre" Padding="8,5" FontSize="13" BorderBrush="#BDBDBD"/>
        </StackPanel>

        <!-- Tipo -->
        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="Tipo *" FontSize="11" Foreground="#757575" Margin="0,0,0,3"/>
            <ComboBox x:Name="CboTipo" Padding="8,5" FontSize="13">
                <ComboBoxItem Content="Material" IsSelected="True"/>
                <ComboBoxItem Content="ManoObra"/>
                <ComboBoxItem Content="Equipo"/>
            </ComboBox>
        </StackPanel>

        <!-- Unidad y Precio -->
        <Grid Grid.Row="3" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Unidad *" FontSize="11" Foreground="#757575" Margin="0,0,0,3"/>
                <TextBox x:Name="TxtUnidad" Padding="8,5" FontSize="13" BorderBrush="#BDBDBD"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Precio" FontSize="11" Foreground="#757575" Margin="0,0,0,3"/>
                <TextBox x:Name="TxtPrecio" Text="0" Padding="8,5" FontSize="13" BorderBrush="#BDBDBD"/>
            </StackPanel>
        </Grid>

        <!-- Rendimiento -->
        <StackPanel Grid.Row="4" Margin="0,0,0,10">
            <TextBlock Text="Rendimiento" FontSize="11" Foreground="#757575" Margin="0,0,0,3"/>
            <TextBox x:Name="TxtRendimiento" Text="1" Padding="8,5" FontSize="13" BorderBrush="#BDBDBD"/>
        </StackPanel>

        <!-- Botones -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="✓ Agregar"
                    Click="BtnAgregar_Click"
                    Background="#E65100" Foreground="White"
                    FontWeight="SemiBold"
                    Padding="16,7" Margin="0,0,8,0"/>
            <Button Content="Cancelar"
                    Click="BtnCancelar_Click"
                    Background="White"
                    BorderBrush="#BDBDBD" BorderThickness="1"
                    Padding="16,7"/>
        </StackPanel>
    </Grid>
</Window>
